<section class="pcoded-main-container">
    <div class="pcoded-wrapper">
        <div class="pcoded-content">
            <div class="pcoded-inner-content">
                <div class="main-body">
                    <div class="page-wrapper">
                        <div class="page-header">
                            <div class="page-block">
                                <div class="row align-items-center">
                                    <div class="col-md-12">
                                        <div class="page-header-title">
                                            <h5 class="m-b-10">Issue List</h5>
                                        </div>
                                        <ul class="breadcrumb">
                                            <li class="breadcrumb-item"><a href="/books"><i class="feather icon-home"></i></a></li>
                                            <li class="breadcrumb-item"><a href="#!">Issue List</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
 
                        <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <%= success %>
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <% } %>

                        <div class="row">
                            <div class="col-sm-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>Issue List</h5>
                                        <div class="card-header-right">
                                            <a href="/issues/add" class="btn btn-primary"><i class="fa fa-book"></i> Issue Book</a>
                                        </div>
                                    </div>
                                    <div class="card-body task-data">
                                        <div class="table-responsive">
                                            <table id="simpletable" class="table dt-responsive table-striped table-bordered nowrap">
                                                <thead>
                                                    <tr>
                                                        <th>Id</th>
                                                        <th>Book Name</th>
                                                        <th>Student Name</th>
                                                        <th>Issue Date</th>
                                                        <th>Return Date</th>
                                                        <th>Status</th>
                                                        <th>Action</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% issues.forEach(issue => { %>
                                                    <tr>
                                                        <td><%= issue.id %></td>
                                                        <td><%= issue.Book.book_name %></td>
                                                        <td><%= issue.Student.name %></td>
                                                        <td><%= issue.issue_date %></td>
                                                        <td><%= issue.return_date || '-' %></td>
                                                        <td><%= issue.status %></td>
                                                        <td>
                                                            <% if (issue.status === 'issued') { %>
                                                            <a href="/issues/return/<%= issue.id %>" class="btn btn-sm btn-warning">Return</a>
                                                            <% } %>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    setTimeout(function() {
        $('#simpletable').DataTable();
    }, 600);
</script>