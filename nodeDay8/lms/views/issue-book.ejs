<section class="pcoded-main-container">
    <div class="pcoded-wrapper">
        <div class="pcoded-content">
            <div class="pcoded-inner-content">
                <div class="main-body">
                    <div class="page-wrapper">
                        <div class="page-header">
                            <div class="page-block">
                                <div class="row align-items-center">
                                    <div class="col-md-12">
                                        <div class="page-header-title">
                                            <h5 class="m-b-10">Issue Book</h5>
                                        </div>
                                        <ul class="breadcrumb">
                                            <li class="breadcrumb-item"><a href="/books"><i class="feather icon-home"></i></a></li>
                                            <li class="breadcrumb-item"><a href="/issues">Issue List</a></li>
                                            <li class="breadcrumb-item"><a href="#!">Issue Book</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>Issue Book</h5>
                                    </div>
                                    <div class="card-body task-data">
                                        <% if (error) { %>
                                        <div class="alert alert-danger"><%= error %></div>
                                        <% } %>
                                        <form action="/issues/add" method="POST">
                                            <div class="form-group row">
                                                <label class="col-sm-3 col-form-label">Book Name</label>
                                                <div class="col-sm-6">
                                                    <select name="book_id" class="form-control" required>
                                                        <option value="">Select Book</option>
                                                        <% books.forEach(book => { %>
                                                        <option value="<%= book.id %>"><%= book.book_name %> (<%= book.isbn %>)</option>
                                                        <% }) %>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="col-sm-3 col-form-label">Student Name</label>
                                                <div class="col-sm-6">
                                                    <select name="student_id" class="form-control" required>
                                                        <option value="">Select Student</option>
                                                        <% students.forEach(student => { %>
                                                        <option value="<%= student.id %>"><%= student.name %> (<%= student.roll_no %>)</option>
                                                        <% }) %>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <div class="col-sm-9 text-right">
                                                    <button type="submit" class="btn btn-primary">Issue</button>
                                                    <a href="/issues" class="btn btn-danger">Cancel</a>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>