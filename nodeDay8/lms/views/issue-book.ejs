<section class="pcoded-main-container">
    <div class="pcoded-wrapper">
        <div class="pcoded-content">
            <div class="pcoded-inner-content">
                <div class="main-body">
                    <div class="page-wrapper">
                        <div class="page-header">
                            <div class="page-block">
                                <div class="row align-items-center">
                                    <div class="col-md-12">
                                        <div class="page-header-title">
                                            <h5 class="m-b-10">Issue Book</h5>
                                        </div>
                                        <ul class="breadcrumb">
                                            <li class="breadcrumb-item"><a href="/books"><i class="feather icon-home"></i></a></li>
                                            <li class="breadcrumb-item"><a href="/issues">Issue List</a></li>
                                            <li class="breadcrumb-item"><a href="#!">Issue Book</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5>Issue Book</h5>
                                    </div>
                                    <div class="card-body task-data">
                                        <div id="errorAlert" class="alert alert-danger" style="display:none;"></div>
                                        <div id="successAlert" class="alert alert-success" style="display:none;"></div>
                                        <form id="issueBookForm">
                                            <div class="form-group row">
                                                <label class="col-sm-3 col-form-label">Book Name</label>
                                                <div class="col-sm-6">
                                                    <select name="book_id" class="form-control">
                                                        <option value="">Select Book</option>
                                                        <% books.forEach(book => { %>
                                                        <option value="<%= book.id %>"><%= book.book_name %> (<%= book.isbn %>)</option>
                                                        <% }) %>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <label class="col-sm-3 col-form-label">Student Name</label>
                                                <div class="col-sm-6">
                                                    <select name="student_id" class="form-control">
                                                        <option value="">Select Student</option>
                                                        <% students.forEach(student => { %>
                                                        <option value="<%= student.id %>"><%= student.name %> (<%= student.roll_no %>)</option>
                                                        <% }) %>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="form-group row">
                                                <div class="col-sm-9 text-right">
                                                    <button type="submit" class="btn btn-primary">Issue</button>
                                                    <a href="/issues" class="btn btn-danger">Cancel</a>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $('#issueBookForm').on('submit', function(e) {
        e.preventDefault();
        $('#errorAlert').hide();
        $('#successAlert').hide();

        var bookId = $('select[name="book_id"]').val();
        var studentId = $('select[name="student_id"]').val();

        if (!bookId) {
            $('#errorAlert').text('Please select a book').show();
            return;
        }
        if (!studentId) {
            $('#errorAlert').text('Please select a student').show();
            return;
        }

        $('button[type="submit"]').prop('disabled', true).text('Issuing...');

        $.ajax({
            url: '/issues/add',
            type: 'POST',
            data: {
                book_id: bookId,
                student_id: studentId
            },
            success: function(response) {
                if (response.success) {
                    window.location.href = '/issues?success=Book issued successfully';
                } else {
                    $('#errorAlert').text(response.message).show();
                    $('button[type="submit"]').prop('disabled', false).text('Issue');
                }
            },
            error: function() {
                $('#errorAlert').text('Something went wrong').show();
                $('button[type="submit"]').prop('disabled', false).text('Issue');
            }
        });
    });
</script>